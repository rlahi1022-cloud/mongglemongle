{
  "title": "Monggle 백엔드 운영",
  "schemaVersion": 38,
  "version": 1,
  "tags": ["monggle"],
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "title": "RPS (방법별)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (method) (rate(http_requests_total[1m]))", "legendFormat": "{{method}}" }
      ]
    },
    {
      "title": "응답 시간 P50 / P95 / P99",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket[1m])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[1m])))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket[1m])))", "legendFormat": "p99" }
      ]
    },
    {
      "title": "캐시 hit / miss",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (layer) (rate(cache_hits_total[1m]))", "legendFormat": "hit · {{layer}}" },
        { "expr": "rate(cache_misses_total[1m])", "legendFormat": "miss" }
      ]
    },
    {
      "title": "캐시 hit ratio",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "green", "value": 0.8 }] }
        }
      },
      "targets": [
        { "expr": "sum(rate(cache_hits_total[5m])) / (sum(rate(cache_hits_total[5m])) + sum(rate(cache_misses_total[5m])))" }
      ]
    },
    {
      "title": "Rate-limit 거부율",
      "type": "timeseries",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum by (group) (rate(ratelimit_denied_total[1m]))", "legendFormat": "{{group}}" }
      ]
    },
    {
      "title": "상태 코드 분포",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (status) (rate(http_requests_total[1m]))", "legendFormat": "{{status}}" }
      ]
    },
    {
      "title": "Redis 헬스",
      "type": "stat",
      "gridPos": { "x": 12, "y": 16, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }]
        }
      },
      "targets": [{ "expr": "redis_up" }]
    },
    {
      "title": "스냅샷 워커 — 마지막 사이클 사용자 수",
      "type": "stat",
      "gridPos": { "x": 18, "y": 16, "w": 6, "h": 4 },
      "targets": [{ "expr": "snapshot_worker_last_cycle_users" }]
    }
  ]
}
