# 로컬 개발 환경 변수. 실제 값은 .env 로 복사해서 사용 (.env 는 git 무시)
MONGGLE_HTTP_HOST=0.0.0.0
MONGGLE_HTTP_PORT=8080

MONGGLE_DB_HOST=127.0.0.1
MONGGLE_DB_PORT=3306
MONGGLE_DB_NAME=monggle
MONGGLE_DB_USER=monggle
MONGGLE_DB_PASSWORD=monggle_dev
MONGGLE_DB_POOL_SIZE=8

MONGGLE_REDIS_HOST=127.0.0.1
MONGGLE_REDIS_PORT=6379
MONGGLE_REDIS_POOL_SIZE=4

# AI 허브 (Python FastAPI, docker compose ai-hub)
MONGGLE_AI_HUB_BASE_URL=http://127.0.0.1:9100
MONGGLE_AI_HUB_TIMEOUT_MS=5000

# S3 (로컬: MinIO, 운영: AWS S3) — MVP는 미사용
MONGGLE_S3_ENDPOINT=http://127.0.0.1:9000
MONGGLE_S3_BUCKET=monggle-media
MONGGLE_S3_ACCESS_KEY=monggle_admin
MONGGLE_S3_SECRET_KEY=monggle_dev_secret
MONGGLE_S3_REGION=us-east-1
